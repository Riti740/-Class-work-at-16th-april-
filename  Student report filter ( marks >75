        "f = open(\"students.txt\", \"r\")\n",
        "newf = open(\"top_students.txt\", \"w\")\n",
        "\n",
        "for line in f:\n",
        "    name, marks, city = line.strip().split(\",\")\n",
        "        if int(marks) > 75:\n",
        "                newf.write(line)\n",
        "\n",
        "                f.close()\n",
        "                newf.close()\n",
        "\n",
        "                print(\"Filtered students saved\")"
