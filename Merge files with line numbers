      "cell_type": "code",
      "source": [
        "f1 = open(\"file1.txt\", \"r\")\n",
        "f2 = open(\"file2.txt\", \"r\")\n",
        "newf = open(\"merged.txt\", \"w\")\n",
        "\n",
        "lines = f1.readlines() + f2.readlines()\n",
        "\n",
        "for i, line in enumerate(lines, start=1):\n",
        "    newf.write(str(i) + \". \" + line)\n",
        "\n",
        "    f1.close()\n",
        "    f2.close()\n",
        "    newf.close()"
