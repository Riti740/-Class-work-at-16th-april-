      "source": [
        "import re\n",
        "\n",
        "f = open(\"data.txt\", \"r\")\n",
        "text = f.read()\n",
        "\n",
        "emails = re.findall(r'\\S+@\\S+', text)\n",
        "\n",
        "newf = open(\"emails.txt\", \"w\")\n",
        "for e in emails:\n",
        "    newf.write(e + \"\\n\")\n",
        "\n",
        "    f.close()\n",
        "    newf.close()"
