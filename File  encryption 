      "source": [
        "f = open(\"file.txt\", \"r\")\n",
        "text = f.read()\n",
        "\n",
        "shift = 3\n",
        "encrypted = \"\"\n",
        "\n",
        "for ch in text:\n",
        "    encrypted += chr(ord(ch) + shift)\n",
        "\n",
        "    newf = open(\"encrypted.txt\", \"w\")\n",
        "    newf.write(encrypted)\n",
        "\n",
        "    f.close()\n",
        "    newf.close()"
