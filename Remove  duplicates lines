      "cell_type": "code",
      "source": [
        "f = open(\"file.txt\", \"r\")\n",
        "lines = f.readlines()\n",
        "\n",
        "unique = []\n",
        "for line in lines:\n",
        "    if line not in unique:\n",
        "            unique.append(line)\n",
        "\n",
        "            newf = open(\"newfile.txt\", \"w\")\n",
        "            newf.writelines(unique)\n",
        "\n",
        "            f.close()\n",
        "            newf.close()"
      ],
