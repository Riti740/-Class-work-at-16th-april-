      "source": [
        "f = open(\"file.txt\", \"r\")\n",
        "\n",
        "longest = \"\"\n",
        "\n",
        "for line in f:\n",
        "    if len(line) > len(longest):\n",
        "            longest = line\n",
        "\n",
        "            print(\"Longest line:\", longest)\n",
        "            print(\"Length:\", len(longest))\n",
        "\n",
        "            f.close()"
